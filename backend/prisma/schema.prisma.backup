generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  DEALER
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole

  dealerId     String?
  dealer       Dealer?  @relation(fields: [dealerId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Dealer {
  id        String @id @default(cuid())
  name      String
  city      String?

  users     User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}