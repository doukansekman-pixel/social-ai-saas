generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  DEALER
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole

  dealerId     String?
  dealer       Dealer?  @relation(fields: [dealerId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Dealer {
  id                String   @id @default(cuid())
  name              String
  city              String?
  contactName       String?
  phone             String?
  email             String?
  instagramUsername String?
  primaryColor      String?
  dealerType        String   @default("TIPICO")
  isActive          Boolean  @default(true)

  users             User[]
  instagramAccount  InstagramAccount?
  posts             Post[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model InstagramAccount {
  id                 String   @id @default(cuid())

  dealerId           String   @unique
  dealer             Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  instagramUsername  String?
  instagramAccountId String?
  facebookPageId     String?
  accessToken        String?
  tokenExpiresAt     DateTime?
  isConnected        Boolean  @default(false)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Post {
  id           String   @id @default(cuid())

  dealerId     String
  dealer       Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  title        String
  caption      String
  hashtags     String
  offer        String
  designBrief  String?
  imagePrompt  String?
  imageUrl     String?

  status       String   @default("draft")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model WeeklyMatch {
  id          String   @id @default(cuid())

  sourceName  String?
  sport       String?
  competition String?
  matchCode   String?
  matchDay    String?
  matchDate   String?
  matchTime   String?

  homeTeam    String
  awayTeam    String

  importance  Int      @default(0)
  aiReason    String?
  status      String   @default("active")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
